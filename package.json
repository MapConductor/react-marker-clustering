{
  "name": "@mapconductor/react-marker-clustering",
  "version": "0.1.1",
  "description": "Marker clustering for MapConductor React SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.native.d.ts",
        "import": "./dist/index.native.mjs",
        "require": "./dist/index.native.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "android",
    "ios",
    "MapConductorReactMarkerClustering.podspec",
    "react-native.config.js",
    "dist",
    "README.ja.md",
    "README.es-419.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/index.native.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/index.native.ts --format cjs,esm --watch",
    "clean": "rm -rf dist",
    "test": "echo 'No tests yet'"
  },
  "keywords": [
    "maps",
    "clustering",
    "markers",
    "react",
    "typescript"
  ],
  "author": "MapConductor",
  "license": "Apache2",
  "dependencies": {
    "@mapconductor/js-sdk-core": "0.1.1",
    "@mapconductor/js-sdk-react": "0.1.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
